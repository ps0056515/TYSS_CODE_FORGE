# CodeForge – copy to .env.local and fill in values

# NextAuth (required for OAuth)
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=generate-a-random-string-e-g-openssl-rand-base64-32

# Google OAuth (optional – enable “Sign in with Google”)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add these Authorized redirect URIs in the OAuth 2.0 Client ID:
#   - http://localhost:3002/api/auth/callback/google   (local)
#   - https://your-domain.com/api/auth/callback/google   (production – add each deployment URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional – enable “Sign in with GitHub”)
# Create OAuth App at https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# Admin users (optional – comma-separated usernames or emails; else admin/trainer prefix)
# CODEFORGE_ADMINS=admin@company.com,trainer1
